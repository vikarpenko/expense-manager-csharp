<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ExpenseManager.UIModels;assembly=ExpenseManager.UIModels"
             x:Class="ExpenseManager.Components.WalletCardView"
             x:DataType="models:WalletUIModel">

    <Border Style="{StaticResource WalletCardStyle}">
        <Grid ColumnDefinitions="*,Auto">

            <Label Text="{Binding Name}"
                   Style="{StaticResource WalletTitleStyle}" />

            <Label Grid.Column="1"
                   Text="{Binding Currency}"
                   Style="{StaticResource WalletMetaStyle}"
                   HorizontalOptions="End" />
        </Grid>
    </Border>
</ContentView>